---
import { Image } from 'astro:assets';
import type { CharacterInfo } from '../lib/assets';

interface Props {
  character: CharacterInfo;
  state?: keyof CharacterInfo['states'];
}
const { character, state = 'optimal' } = Astro.props;
---

<article class="char-card card">
  <div class="art" style={`--accent:${character.accent}`}>
    <Image
      src={character.states[state]}
      alt={`글루밍즈 캐릭터 ${character.name}`}
      width={220}
      height={220}
      densities={[1, 2]}
    />
  </div>
  <div class="meta">
    <h3>{character.name}</h3>
    <p>{character.tagline}</p>
  </div>
</article>

<style>
  .char-card {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    text-align: center;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .char-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  .art {
    border-radius: var(--r-lg);
    background:
      radial-gradient(circle at 50% 38%, color-mix(in srgb, var(--accent) 22%, transparent), transparent 65%),
      var(--card-soft);
    display: grid;
    place-items: center;
    padding: 14px;
    aspect-ratio: 1 / 1;
  }
  .art :global(img) {
    width: 78%;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 10px 18px rgba(58, 45, 31, 0.16));
  }
  .meta h3 {
    font-size: 20px;
  }
  .meta p {
    margin-top: 6px;
    color: var(--text-2);
    font-size: 14px;
    line-height: 1.6;
  }
</style>
