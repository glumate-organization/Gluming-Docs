---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  img: ImageMetadata;
  title: string;
  tint?: string; // CSS 변수 (예: var(--primary-bg))
  alt?: string;
}
const { img, title, tint = 'var(--primary-bg)', alt = '' } = Astro.props;
---

<article class="feature-card card">
  <div class="thumb" style={`background:${tint}`}>
    <Image src={img} alt={alt} width={120} height={120} densities={[1, 2]} />
  </div>
  <h3>{title}</h3>
  <p><slot /></p>
</article>

<style>
  .feature-card {
    padding: 26px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    height: 100%;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  .thumb {
    width: 72px;
    height: 72px;
    border-radius: var(--r-lg);
    display: grid;
    place-items: center;
    overflow: hidden;
  }
  .thumb :global(img) {
    width: 52px;
    height: 52px;
    object-fit: contain;
  }
  .feature-card h3 {
    font-size: 20px;
  }
  .feature-card p {
    color: var(--text-2);
    font-size: 15px;
    line-height: 1.7;
  }
</style>
