---
// 정책/정보 문서 공통 레이아웃 (개인정보·약관·의료 정보 기준).
// 좁은 읽기 폭 + 헤어라인 + 세리프 eyebrow. 본문은 slot으로 받는다.
interface Props {
  eyebrow: string; // 영문 세리프 eyebrow
  title: string; // 문서 제목 (국문)
  lead?: string; // 도입 한 줄
  updated?: string; // 최종 업데이트
  version?: string; // 버전
}
const { eyebrow, title, lead, updated, version } = Astro.props;
---

<article class="doc">
  <header class="doc-head container">
    <p class="doc-eyebrow">{eyebrow}</p>
    <h1 class="doc-title">{title}</h1>
    {lead && <p class="doc-lead">{lead}</p>}
    {
      (updated || version) && (
        <p class="doc-meta">
          {version && <span>버전 {version}</span>}
          {version && updated && <span class="dot" aria-hidden="true">·</span>}
          {updated && <span>최종 업데이트 {updated}</span>}
        </p>
      )
    }
  </header>

  <div class="doc-body container">
    <slot />
  </div>
</article>

<style>
  .doc {
    padding-top: clamp(48px, 7vw, 96px);
    padding-bottom: clamp(72px, 10vw, 140px);
  }
  .container {
    width: min(var(--measure), calc(100% - 48px));
    margin-inline: auto;
  }
  .doc-head {
    padding-bottom: 40px;
    margin-bottom: 48px;
    border-bottom: 1px solid var(--rule);
  }
  .doc-eyebrow {
    font-family: var(--font-serif);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--sage-dark);
    margin-bottom: 18px;
  }
  .doc-title {
    font-size: clamp(30px, 5vw, 46px);
    letter-spacing: -0.04em;
    line-height: 1.12;
  }
  .doc-lead {
    margin-top: 20px;
    color: var(--text-2);
    font-size: 17px;
    line-height: 1.75;
  }
  .doc-meta {
    margin-top: 24px;
    color: var(--text-3);
    font-size: 13px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .doc-meta .dot {
    color: var(--rule);
  }

  /* ── 본문 타이포 (slot 내부는 :global) ── */
  .doc-body {
    font-size: 15.5px;
    line-height: 1.8;
    color: var(--text);
  }
  .doc-body :global(h2) {
    font-size: clamp(20px, 2.6vw, 25px);
    letter-spacing: -0.03em;
    margin: 56px 0 18px;
    padding-top: 28px;
    border-top: 1px solid var(--rule);
  }
  .doc-body :global(h2:first-child) {
    margin-top: 0;
    padding-top: 0;
    border-top: 0;
  }
  .doc-body :global(h3) {
    font-size: 17px;
    letter-spacing: -0.02em;
    margin: 32px 0 12px;
    color: var(--pine);
  }
  .doc-body :global(p) {
    margin: 14px 0;
    color: var(--text);
  }
  .doc-body :global(a) {
    color: var(--sage-dark);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--sand);
    transition: text-decoration-color 0.18s ease;
  }
  .doc-body :global(a:hover) {
    text-decoration-color: var(--sage-dark);
  }
  .doc-body :global(ul),
  .doc-body :global(ol) {
    margin: 14px 0;
    padding-left: 22px;
  }
  .doc-body :global(li) {
    margin: 7px 0;
  }
  .doc-body :global(li::marker) {
    color: var(--sand);
  }
  .doc-body :global(strong) {
    font-weight: 700;
    color: var(--text);
  }
  .doc-body :global(hr) {
    border: 0;
    border-top: 1px solid var(--rule);
    margin: 40px 0;
  }

  /* 표 */
  .doc-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 20px 0;
    font-size: 14.5px;
  }
  .doc-body :global(th),
  .doc-body :global(td) {
    text-align: left;
    padding: 12px 14px;
    border-bottom: 1px solid var(--rule);
  }
  .doc-body :global(thead th) {
    color: var(--text-2);
    font-weight: 600;
    font-size: 12.5px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--border-strong);
  }
  .doc-body :global(tbody tr:last-child td) {
    border-bottom: 0;
  }

  /* 고지/주의 블록 */
  .doc-body :global(.notice) {
    margin: 28px 0;
    padding: 22px 24px;
    background: var(--surface);
    border: 1px solid var(--rule);
    border-left: 3px solid var(--sage);
    border-radius: var(--r-md);
    font-size: 15px;
    line-height: 1.75;
  }
  .doc-body :global(.notice strong) {
    color: var(--sage-dark);
  }
  .doc-body :global(.notice.caution) {
    border-left-color: var(--coral);
  }
  .doc-body :global(.notice.caution strong) {
    color: var(--coral);
  }

  /* 출처 목록 */
  .doc-body :global(.sources) {
    font-size: 13.5px;
    color: var(--text-2);
  }

  @media (max-width: 560px) {
    .doc-body :global(table) {
      font-size: 13.5px;
    }
    .doc-body :global(th),
    .doc-body :global(td) {
      padding: 10px 10px;
    }
  }
</style>
