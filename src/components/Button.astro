---
// 재사용 CTA 버튼. variant: primary | secondary | ghost
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'md' | 'lg';
  class?: string;
}
const { href, variant = 'primary', size = 'md', class: cls = '' } = Astro.props;
const external = href.startsWith('http');
---

<a
  href={href}
  class={`btn btn-${variant} btn-${size} ${cls}`}
  {...external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
>
  <slot />
</a>

<style>
  /* 납작한 에디토리얼 버튼 — 그림자·큰 라운드 제거 */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    border-radius: var(--r-sm);
    font-weight: 600;
    letter-spacing: -0.01em;
    border: 1px solid transparent;
    transition:
      background 0.18s ease,
      color 0.18s ease,
      border-color 0.18s ease;
    white-space: nowrap;
  }
  .btn-md {
    min-height: 46px;
    padding: 0 22px;
    font-size: 15px;
  }
  .btn-lg {
    min-height: 54px;
    padding: 0 30px;
    font-size: 16px;
  }
  .btn-primary {
    background: var(--pine);
    color: var(--on-dark);
  }
  .btn-primary:hover {
    background: var(--sage-dark);
  }
  .btn-secondary {
    background: transparent;
    color: var(--text);
    border-color: var(--text);
  }
  .btn-secondary:hover {
    background: var(--text);
    color: var(--bg);
  }
  .btn-ghost {
    background: transparent;
    color: var(--sage-dark);
    padding-left: 4px;
    padding-right: 4px;
  }
  .btn-ghost:hover {
    color: var(--pine);
  }
</style>
