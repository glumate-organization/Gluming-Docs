---
import { Image } from 'astro:assets';
import { logos } from '../lib/assets';
import Button from './Button.astro';

const links = [
  { href: '/features', label: '기능' },
  { href: '/characters', label: '글루밍즈' },
  { href: '/about', label: '소개' },
];
const here = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="nav">
  <div class="container nav-inner">
    <a href="/" class="brand" aria-label="글루밍 홈">
      <Image
        src={logos.icon}
        alt=""
        width={40}
        height={40}
        densities={[1, 2]}
        loading="eager"
      />
      <span class="brand-text">
        글루밍<small>Gluming</small>
      </span>
    </a>

    <nav class="nav-links" aria-label="주요 메뉴">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="nav-link"
            aria-current={here === l.href ? 'page' : undefined}
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="nav-cta">
      <Button href="/about#preregister" size="md">사전예약</Button>
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(16px);
    background: rgba(250, 247, 238, 0.78);
    border-bottom: 1px solid var(--border-light);
  }
  .nav-inner {
    height: var(--nav-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 11px;
    font-weight: 900;
    letter-spacing: -0.04em;
    font-size: 19px;
  }
  .brand :global(img) {
    border-radius: 13px;
    box-shadow: 0 8px 22px rgba(72, 112, 58, 0.16);
  }
  .brand-text {
    line-height: 1;
  }
  .brand small {
    display: block;
    font-size: 11px;
    color: var(--text-2);
    font-weight: 700;
    letter-spacing: 0;
    margin-top: 3px;
  }
  .nav-links {
    display: flex;
    gap: 4px;
    align-items: center;
    margin-left: auto;
    margin-right: 8px;
  }
  .nav-link {
    padding: 10px 14px;
    border-radius: var(--r-pill);
    color: #5f574d;
    font-weight: 700;
    font-size: 14.5px;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .nav-link:hover {
    background: var(--primary-bg);
    color: var(--primary-dark);
  }
  .nav-link[aria-current="page"] {
    color: var(--primary-dark);
    background: var(--primary-bg);
  }

  @media (max-width: 640px) {
    .brand-text small {
      display: none;
    }
    .nav-links {
      gap: 0;
      margin-right: 4px;
    }
    .nav-link {
      padding: 8px 9px;
      font-size: 13.5px;
    }
  }
  @media (max-width: 420px) {
    .nav-cta {
      display: none;
    }
  }
</style>
