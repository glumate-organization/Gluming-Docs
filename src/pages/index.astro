---
import { Image } from 'astro:assets';
import Button from '../components/Button.astro';
import CharacterCard from '../components/CharacterCard.astro';
import FeatureCard from '../components/FeatureCard.astro';
import Layout from '../layouts/Layout.astro';
import { characters, charactersByKey, featureImages } from '../lib/assets';

const dodami = charactersByKey.dodami;

const features = [
  {
    img: featureImages.simulation,
    title: '행동 전 시뮬레이션',
    tint: 'var(--primary-bg)',
    alt: '혈당 흐름을 미리 그려보는 시뮬레이션 일러스트',
    desc: '먹기 전에, 움직이기 전에. 내 혈당 패턴이 어떻게 흐를지 미리 살펴보고 천천히 선택해요.',
  },
  {
    img: featureImages.camera,
    title: '간편한 식사·간식 기록',
    tint: 'var(--peach-bg)',
    alt: '카메라로 식사를 기록하는 일러스트',
    desc: '한 끼도, 작은 간식도 가볍게 남겨요. 기록이 쌓일수록 내 몸의 반응을 더 또렷이 알아가요.',
  },
  {
    img: featureImages.notification,
    title: '부드러운 리마인드',
    tint: 'var(--dusk-bg)',
    alt: '알림으로 부드럽게 안내하는 일러스트',
    desc: '재촉하지 않아요. 잊기 쉬운 순간에 살며시 건네는 알림으로 생활습관 관리를 도와요.',
  },
  {
    img: featureImages.star,
    title: '캐릭터와 함께하는 습관',
    tint: 'var(--gold-bg)',
    alt: '별과 함께 습관을 쌓아가는 일러스트',
    desc: '글루밍즈와 하루하루 작은 기록을 모아요. 혼자가 아니라 함께라서 꾸준함이 즐거워져요.',
  },
];

const segments = [
  {
    badge: '안심·세심',
    tint: 'var(--cheek-bg)',
    accent: 'var(--berry)',
    title: '임신성 당뇨가 신경 쓰이는 분',
    desc: '하루에도 몇 번씩 챙겨야 할 게 많은 시기, 기록과 미리보기로 관리 부담을 한결 덜어드려요.',
  },
  {
    badge: '검진 이후',
    tint: 'var(--gold-bg)',
    accent: 'var(--gold)',
    title: '건강검진 결과가 마음에 걸리는 39–59세',
    desc: '전당뇨·2형이 신경 쓰이기 시작했다면, 검진 결과를 막막함이 아니라 일상의 작은 행동으로 이어가요.',
  },
  {
    badge: '식단 관리',
    tint: 'var(--primary-bg)',
    accent: 'var(--primary)',
    title: '혈당 기반 식단을 챙기는 19–39세',
    desc: '같은 음식도 내 몸은 다르게 반응해요. 그 흐름을 알아가며 나에게 맞는 식사를 스스로 골라요.',
  },
];
---

<Layout
  title="글루밍 · Gluming — 먹기 전에, 움직이기 전에 혈당 흐름을 미리"
  description="글루밍은 CGM 혈당 데이터를 식사·운동 같은 행동으로 연결하는 생활습관 관리 보조 서비스예요. 사후 분석이 아니라 행동 전에 내 혈당 패턴을 미리 시뮬레이션해보세요."
>
  <!-- ── 1. HERO ───────────────────────────────────────── -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">A Wellness Companion</p>
        <h1 class="hero-title">
          나의 몸을 이해하는<br />
          <span class="accent">새로운 방식</span>을<br />
          제안합니다.
        </h1>
        <p class="hero-lead">
          글루밍은 CGM 혈당 데이터를 식사·운동 같은 행동으로 연결해요.
          지나간 숫자를 분석하는 대신, <strong>행동하기 전에</strong> 내 혈당 패턴을
          미리 살펴보는 습관을 함께 만들어요.
        </p>
        <div class="hero-cta">
          <Button href="/about#preregister" variant="primary" size="lg">
            사전예약하고 먼저 받아보기
          </Button>
          <Button href="/features" variant="secondary" size="lg">
            기능 둘러보기
          </Button>
        </div>
        <p class="hero-note">의료기기가 아니에요 · 생활습관 관리를 돕는 웰니스 서비스예요</p>
      </div>

      <div class="hero-visual">
        <div class="hero-panel" aria-hidden="true"></div>
        <Image
          src={dodami.states.optimal}
          alt={`글루밍즈 캐릭터 ${dodami.name}가 산뜻한 표정으로 인사하는 모습`}
          width={360}
          height={360}
          loading="eager"
          densities={[1, 2]}
          class="hero-char"
        />
        <div class="hero-tag">
          <span class="hero-tag-dot" aria-hidden="true"></span>
          <span class="hero-tag-text">오늘의 컨디션 · 산뜻해요</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 2. 문제 정의 ──────────────────────────────────── -->
  <section class="section problem">
    <div class="container">
      <p class="eyebrow">01 — Why Gluming</p>
      <h2 class="section-title">숫자는 쌓이는데,<br />뭘 바꿔야 할지는 막막하죠</h2>
      <p class="section-sub">
        CGM을 차면 혈당 데이터는 자동으로 쌓여요. 하지만 데이터가 곧 행동이 되지는
        않아요. “이미 올랐네”를 확인하는 것과, “이렇게 하면 어떻게 흐를까”를 미리
        그려보는 건 전혀 다른 경험이에요.
      </p>

      <div class="compare">
        <article class="compare-col is-before">
          <span class="compare-tag">지금까지</span>
          <h3>사후 분석</h3>
          <p>식사가 끝난 뒤 그래프를 들여다봐요. 이미 지나간 일이라 다음을 바꾸기 어렵죠.</p>
        </article>
        <article class="compare-col is-after">
          <span class="compare-tag accent">글루밍은</span>
          <h3>행동 전 시뮬레이션</h3>
          <p>먹기 전, 움직이기 전에 패턴을 미리 그려봐요. 오늘의 선택을 내 손으로 바꿔요.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ── 3. 핵심 기능 ──────────────────────────────────── -->
  <section class="section features">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">02 — Core Features</p>
          <h2 class="section-title">행동을 바꾸기 쉽게,<br />부드럽게</h2>
        </div>
        <p class="section-sub">
          복잡한 수치 해석은 글루밍에 맡기고, 나는 오늘 한 걸음만 가볍게 내디뎌요.
        </p>
      </div>

      <div class="feature-grid">
        {
          features.map((f) => (
            <FeatureCard img={f.img} title={f.title} tint={f.tint} alt={f.alt}>
              {f.desc}
            </FeatureCard>
          ))
        }
      </div>

      <div class="center-cta">
        <Button href="/features" variant="secondary" size="md">
          기능 자세히 보기
        </Button>
      </div>
    </div>
  </section>

  <!-- ── 4. 글루밍즈 티저 ──────────────────────────────── -->
  <section class="section friends">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">03 — Meet the Glumings</p>
          <h2 class="section-title">매일을 함께 걷는 친구들</h2>
        </div>
        <p class="section-sub">
          기록도 습관도 혼자 하면 금세 지쳐요. 글루밍즈가 곁에서 오늘의 작은 변화를
          같이 응원해요.
        </p>
      </div>

      <div class="friends-grid">
        {characters.map((c) => <CharacterCard character={c} state="optimal" />)}
      </div>

      <div class="center-cta">
        <Button href="/characters" variant="secondary" size="md">
          글루밍즈 모두 만나기
        </Button>
      </div>
    </div>
  </section>

  <!-- ── 5. 타깃 적합성 ────────────────────────────────── -->
  <section class="section fit">
    <div class="container">
      <p class="eyebrow">04 — Who It's For</p>
      <h2 class="section-title">내 속도에 맞춰,<br />내 방식대로</h2>
      <p class="section-sub">
        의료 서비스를 대신하지 않아요. 일상에서 스스로 챙기는 분께 든든한 곁이 되어드려요.
      </p>

      <div class="fit-list">
        {
          segments.map((s, i) => (
            <article class="fit-row">
              <span class="fit-index">{String(i + 1).padStart(2, '0')}</span>
              <div class="fit-body">
                <span class="fit-badge" style={`color:${s.accent}`}>
                  <span class="fit-badge-dot" style={`background:${s.accent}`} />
                  {s.badge}
                </span>
                <h3>{s.title}</h3>
                <p>{s.desc}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── 6. 최종 CTA ───────────────────────────────────── -->
  <section class="section cta-band-wrap">
    <div class="container">
      <div class="cta-band">
        <p class="eyebrow on-dark">Start Today</p>
        <h2 class="cta-title">오늘의 한 끼,<br />미리 살펴보고 시작해요</h2>
        <p class="cta-sub">
          행동하기 전에 내 혈당 흐름을 그려보는 습관. 글루밍을 가장 먼저 만나보세요.
        </p>
        <div class="cta-actions">
          <Button href="/about#preregister" variant="primary" size="lg">
            사전예약하고 먼저 받아보기
          </Button>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── HERO ─────────────────────────────────────────── */
  .hero {
    padding: clamp(44px, 7vw, 92px) 0 clamp(56px, 8vw, 112px);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.08fr 0.92fr;
    gap: clamp(32px, 5vw, 72px);
    align-items: center;
  }
  .hero-title {
    margin-top: 4px;
    font-size: clamp(36px, 6vw, 68px);
    line-height: 1.08;
    letter-spacing: -0.045em;
  }
  .hero-title .accent {
    position: relative;
    white-space: nowrap;
  }
  .hero-title .accent::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.08em;
    height: 3px;
    background: var(--sand);
  }
  .hero-lead {
    margin-top: 26px;
    max-width: 500px;
    color: var(--text-2);
    font-size: clamp(16px, 2vw, 19px);
    line-height: 1.8;
  }
  .hero-lead strong {
    color: var(--text);
    font-weight: 600;
  }
  .hero-cta {
    margin-top: 32px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }
  .hero-note {
    margin-top: 20px;
    color: var(--text-3);
    font-size: 13.5px;
    font-weight: 600;
  }

  /* 에지 블리드 비주얼 — 캔디 카드 대신 톤 패널 + 여백 */
  .hero-visual {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 380px;
  }
  .hero-panel {
    position: absolute;
    inset: -8% -50vw -8% 4%;
    background: var(--warm);
    border-left: 1px solid var(--rule);
  }
  .hero-char {
    position: relative;
    width: min(84%, 340px);
    height: auto;
    filter: drop-shadow(0 16px 28px rgba(58, 45, 31, 0.14));
  }
  .hero-tag {
    position: absolute;
    bottom: 8%;
    left: 8%;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 9px 15px;
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: var(--r-pill);
    font-size: 13px;
    font-weight: 600;
    color: var(--text-2);
  }
  .hero-tag-dot {
    width: 8px;
    height: 8px;
    border-radius: var(--r-pill);
    background: var(--primary);
  }

  /* ── 공통 섹션 헤드 (비대칭 정렬) ──────────────────── */
  .section-head {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(20px, 4vw, 56px);
    align-items: end;
  }
  .section-head .section-sub {
    margin-top: 0;
    padding-bottom: 6px;
  }

  /* ── 문제 정의 ─────────────────────────────────────── */
  .compare {
    margin-top: clamp(40px, 6vw, 64px);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-top: 1px solid var(--rule);
  }
  .compare-col {
    padding: 36px clamp(24px, 4vw, 44px) 8px 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .compare-col.is-after {
    padding-left: clamp(24px, 4vw, 44px);
    padding-right: 0;
    border-left: 1px solid var(--rule);
  }
  .compare-col h3 {
    font-size: clamp(22px, 3vw, 30px);
  }
  .compare-col.is-before h3 {
    color: var(--text-3);
  }
  .compare-col.is-after h3 {
    color: var(--pine);
  }
  .compare-col p {
    color: var(--text-2);
    font-size: 15.5px;
    line-height: 1.75;
    max-width: 42ch;
  }
  .compare-tag {
    font-family: var(--font-serif);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
  }
  .compare-tag.accent {
    color: var(--sage-dark);
  }

  /* ── 기능 / 글루밍즈 그리드 ───────────────────────── */
  .feature-grid,
  .friends-grid {
    margin-top: clamp(40px, 6vw, 60px);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .center-cta {
    margin-top: 40px;
    display: flex;
    justify-content: center;
  }

  /* ── 타깃 적합성 — 헤어라인 리스트 ─────────────────── */
  .fit-list {
    margin-top: clamp(40px, 6vw, 60px);
    border-top: 1px solid var(--rule);
  }
  .fit-row {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: clamp(16px, 3vw, 40px);
    padding: clamp(28px, 4vw, 40px) 0;
    border-bottom: 1px solid var(--rule);
  }
  .fit-index {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 500;
    color: var(--sand);
    letter-spacing: 0.02em;
    padding-top: 4px;
  }
  .fit-body {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: var(--measure);
  }
  .fit-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12.5px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }
  .fit-badge-dot {
    width: 7px;
    height: 7px;
    border-radius: var(--r-pill);
  }
  .fit-row h3 {
    font-size: clamp(20px, 2.6vw, 26px);
    line-height: 1.3;
  }
  .fit-row p {
    color: var(--text-2);
    font-size: 15.5px;
    line-height: 1.75;
  }

  /* ── 최종 CTA — 파인 다크 밴드 (플랫) ──────────────── */
  .cta-band {
    padding: clamp(52px, 8vw, 96px) clamp(28px, 5vw, 72px);
    border-radius: var(--r-lg);
    text-align: center;
    background: var(--pine);
    color: var(--on-dark);
  }
  .eyebrow.on-dark {
    color: var(--primary-light);
  }
  .cta-title {
    font-size: clamp(28px, 4.4vw, 46px);
    letter-spacing: -0.04em;
    line-height: 1.14;
    color: var(--on-dark);
  }
  .cta-sub {
    margin: 20px auto 34px;
    max-width: 500px;
    font-size: clamp(15px, 2vw, 18px);
    line-height: 1.75;
    color: color-mix(in srgb, var(--on-dark) 78%, transparent);
  }
  .cta-actions {
    display: flex;
    justify-content: center;
  }
  .cta-band :global(.btn-primary) {
    background: var(--on-dark);
    color: var(--pine);
  }
  .cta-band :global(.btn-primary:hover) {
    background: #ffffff;
  }

  /* ── 반응형 ────────────────────────────────────────── */
  @media (max-width: 980px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
    .hero-copy {
      text-align: center;
    }
    .hero-lead {
      margin-inline: auto;
    }
    .hero-cta {
      justify-content: center;
    }
    .hero-visual {
      order: -1;
      min-height: 320px;
    }
    .hero-panel {
      inset: -6% -24px -6% -24px;
      border-left: 0;
      border-radius: var(--r-lg);
    }
    .hero-tag {
      left: 50%;
      transform: translateX(-50%);
    }
    .section-head {
      grid-template-columns: 1fr;
      align-items: start;
    }
    .feature-grid,
    .friends-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .compare {
      grid-template-columns: 1fr;
    }
    .compare-col {
      padding: 32px 0;
      border-bottom: 1px solid var(--rule);
    }
    .compare-col:last-child {
      border-bottom: 0;
    }
    .compare-col.is-after {
      padding-left: 0;
      border-left: 0;
    }
  }

  @media (max-width: 560px) {
    .feature-grid,
    .friends-grid {
      grid-template-columns: 1fr;
    }
    .fit-row {
      grid-template-columns: 1fr;
      gap: 12px;
    }
    .fit-index {
      padding-top: 0;
    }
  }
</style>
