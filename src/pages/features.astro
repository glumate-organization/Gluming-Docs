---
import { Image } from 'astro:assets';
import AppScreen from '../components/AppScreen.astro';
import Button from '../components/Button.astro';
import Layout from '../layouts/Layout.astro';
import { characters, featureImages, healthImages, oauthImages } from '../lib/assets';

const title = '기능 — 행동 전에 살펴보는 혈당 관리 습관 도구 · 글루밍';
const description =
  '글루밍의 기능을 한눈에 살펴보세요. 식사·운동 전에 내 혈당이 어떻게 변할지 미리 보고, 간편하게 기록하며, 부드러운 알림과 글루밍즈 캐릭터로 꾸준한 습관을 응원해요.';

// 딥다이브 기능 행 — 이미지/텍스트 좌우 교차 배치로 리듬을 만든다.
const deepDives = [
  {
    eyebrow: 'See your glucose ahead',
    title: '혈당 변화 미리보기',
    variant: 'preview',
    img: featureImages.simulation,
    alt: '식사·운동 전 예상 혈당 변화를 그래프로 미리 보여주는 화면 일러스트',
    lead:
      '“이 메뉴를 먹으면, 지금 잠깐 산책하면 내 혈당은 어떻게 변할까요?”<br />' +
      '이미 오른 혈당을 뒤늦게 확인하는 대신, <strong>행동하기 전에</strong> 내 혈당이 어떻게 변할지 미리 보여드려요.<br />' +
      '무엇을 하면 좋을지까지 함께 귀띔해 주니까, 오늘의 관리가 한결 쉬워져요.',
    tint: 'var(--primary-bg)',
    points: [
      '식사·간식·운동을 하기 전에 예상 흐름을 먼저 살펴봐요',
      '여러 선택지를 나란히 두고 마음 편한 쪽을 골라요',
      '결과를 단정하지 않고, 참고할 수 있는 흐름으로 보여드려요',
    ],
  },
  {
    eyebrow: 'The whole day at a glance',
    title: '잠깐 뒤부터 하루까지, 미리 보기',
    variant: 'horizon',
    img: featureImages.star,
    alt: '30분 뒤부터 하루까지 혈당 흐름을 한눈에 모아 보여주는 카드 일러스트',
    lead:
      '지금 이 순간만 보는 게 아니라, 30분 뒤·2시간 뒤·하루까지 내 혈당이 어떻게 흐를지 한눈에 펼쳐서 보여드려요.<br />' +
      '“나는 아침을 먹으면 이렇게 되는구나” 하고 <strong>나만 반복되는 흐름</strong>이 보이기 시작하면, 다음 선택이 한결 가벼워져요.',
    tint: 'var(--dusk-bg)',
    points: [
      '30분 뒤부터 하루까지, 시간대별로 모아서 봐요',
      '나에게 자주 반복되는 흐름을 편하게 알아가요',
      '오늘 컨디션에 맞춰 흐름을 가볍게 견줘 봐요',
    ],
  },
  {
    eyebrow: 'Easy logging',
    title: '식사 · 간식 기록',
    variant: 'record',
    img: featureImages.camera,
    alt: '카메라로 식사 사진을 찍어 간편하게 기록하는 화면 일러스트',
    lead:
      '기록이 숙제처럼 느껴지면 오래가기 어렵잖아요.<br />' +
      '그래서 글루밍은 카메라로 <strong>한 번 찍어</strong> 가볍게 남기고, 깜빡하기 쉬운 간식도 톡 더하는 정도로 최대한 단순하게 만들었어요.<br />' +
      '이렇게 쌓인 기록이 다음 미리보기를 더 똑똑하게 만들어줘요.',
    tint: 'var(--coral-bg)',
    points: [
      '카메라로 사진 한 장, 메모는 선택이라 부담이 적어요',
      '식사 사이의 작은 간식도 가볍게 남길 수 있어요',
      '쌓인 기록이 다음 미리보기의 든든한 재료가 돼요',
    ],
  },
  {
    eyebrow: 'Gentle nudges',
    title: '부드러운 알림',
    variant: 'remind',
    img: featureImages.notification,
    alt: '식후 가벼운 산책을 부드럽게 제안하는 알림 일러스트',
    lead:
      '재촉하지 않을게요.<br />' +
      '식사 뒤 가벼운 산책처럼, 오늘 도움이 될 만한 <strong>작은 행동</strong>을 알맞은 순간에 살며시 건네요.<br />' +
      '알림은 언제든 내 리듬에 맞게 조절할 수 있어요.',
    tint: 'var(--peach-bg)',
    points: [
      '식후 가벼운 산책 같은 작은 행동을 부담 없이 제안해요',
      '강요 대신 “해볼까요?” 하고 살며시 건네요',
      '알림 시점과 빈도는 내 생활 리듬에 맞춰 조절해요',
    ],
  },
  {
    eyebrow: 'Habit & rewards',
    title: '캐릭터와 함께하는 습관 · 미션 · 리워드',
    variant: 'reward',
    img: featureImages.candy,
    alt: '미션을 완료하면 받는 리워드와 캐릭터 일러스트',
    lead:
      '혼자보다 함께일 때 더 오래가요.<br />' +
      '글루밍즈 친구들과 작은 미션을 하나씩 채워가다 보면, 꾸준함에 응원과 <strong>리워드</strong>가 따라와요.<br />' +
      '부담 없는 재미로 습관이 자연스럽게 이어지도록 도와드릴게요.',
    tint: 'var(--gold-bg)',
    points: [
      '오늘의 작은 미션으로 습관을 한 걸음씩 쌓아요',
      '꾸준함에 리워드와 수집 요소로 재미를 더해요',
      '글루밍즈 친구들이 옆에서 함께 응원해요',
    ],
  },
];

const healthPlatforms = [
  {
    img: healthImages.appleHealth,
    name: 'Apple 건강',
    os: 'iOS',
    alt: 'Apple 건강 앱 로고',
  },
  {
    img: healthImages.healthConnect,
    name: 'Health Connect',
    os: 'Android',
    alt: 'Android Health Connect 로고',
  },
];

const oauthOptions = [
  { img: oauthImages.google, name: 'Google', alt: 'Google 로그인 아이콘' },
  { img: oauthImages.apple, name: 'Apple', alt: 'Apple 로그인 아이콘' },
  { img: oauthImages.kakao, name: '카카오', alt: '카카오 로그인 아이콘' },
  { img: oauthImages.naver, name: '네이버', alt: '네이버 로그인 아이콘' },
];

// 인사용 글루밍즈 일부
const greetChars = characters.slice(0, 4);
---

<Layout title={title} description={description}>
  <!-- 1. HERO -->
  <section class="section hero">
    <div class="container hero-inner">
      <span class="eyebrow">00 — FEATURES</span>
      <h1 class="hero-title">행동하기 전에, 내 혈당 흐름을 먼저 살펴봐요</h1>
      <p class="hero-lead">
        지나간 숫자를 되짚기보다, 식사나 운동처럼 무언가를 하기
        <strong>전에</strong> 예상 흐름을 먼저 그려봐요.<br />
        가볍게 비교해 보고, 참고만 하고, 결국 선택은 내가 하는 거예요.<br />
        내 몸을 조금 더 이해하는 새로운 방법, 어떠세요?
      </p>
      <div class="hero-actions">
        <Button href="/about#preregister" variant="primary" size="lg">
          사전예약하고 먼저 만나보기
        </Button>
        <Button href="#health-sync" variant="ghost" size="lg">
          건강 데이터 연동 보기 →
        </Button>
      </div>
    </div>
  </section>

  <!-- 2. DEEP-DIVE 기능 행 -->
  <section class="section deepdives">
    <div class="container">
      {
        deepDives.map((f, i) => {
          const num = String(i + 1).padStart(2, '0');
          return (
            <article class={`row ${i % 2 === 1 ? 'row-reverse' : ''}`}>
              <div class="row-media">
                <AppScreen variant={f.variant} />
              </div>
              <div class="row-text">
                <span class="eyebrow">{`${num} — ${f.eyebrow}`}</span>
                <h2 class="row-title">{f.title}</h2>
                <p class="row-lead" set:html={f.lead} />
                <ul class="row-points">
                  {f.points.map((p) => (
                    <li>{p}</li>
                  ))}
                </ul>
              </div>
            </article>
          );
        })
      }
    </div>
  </section>

  <!-- 3. 건강 데이터 연동 -->
  <section id="health-sync" class="section sync">
    <hr class="rule" />
    <div class="container">
      <div class="sync-head">
        <span class="eyebrow">06 — HEALTH SYNC</span>
        <h2 class="section-title">기기와 직접 씨름하지 않아요</h2>
        <p class="section-sub">
          글루밍은 걸음 수나 활동량 같은 건강 데이터를 운영체제의 건강 플랫폼을
          통해 살며시 읽어와요.<br />
          iOS는 <strong>Apple 건강</strong>, Android는 <strong>Health Connect</strong>와
          연동돼요.<br />
          기기와 블루투스로 직접 씨름하지 않아서, 더 단순하고 마음 편하게 쓸 수 있어요.
        </p>
      </div>
      <div class="sync-chips">
        {
          healthPlatforms.map((h) => (
            <div class="sync-chip">
              <Image src={h.img} alt={h.alt} width={56} height={56} densities={[1, 2]} />
              <div class="sync-chip-text">
                <strong>{h.name}</strong>
                <span>{h.os}</span>
              </div>
            </div>
          ))
        }
      </div>
      <p class="sync-note">
        연동은 언제든 직접 켜고 끌 수 있어요.<br />
        어떤 데이터를 가져올지도 스스로 고를 수 있고요.<br />
        글루밍은 건강 관리를 돕는 <strong>보조 도구</strong>예요. 전문적인 진료나
        상담을 대신하지 않고, 곁에서 살포시 거들게요.
      </p>
    </div>
  </section>

  <!-- 4. 간편 로그인 -->
  <section class="section login">
    <hr class="rule" />
    <div class="container login-inner">
      <div class="login-text">
        <span class="eyebrow">07 — SIGN IN</span>
        <h2 class="section-title">익숙한 계정으로 가볍게 시작해요</h2>
        <p class="section-sub">
          복잡한 가입 절차는 건너뛸게요.<br />
          평소 쓰던 계정으로 <strong>바로</strong> 시작할 수 있어요.
        </p>
      </div>
      <ul class="login-icons" aria-label="간편 로그인 옵션">
        {
          oauthOptions.map((o) => (
            <li class="login-chip">
              <Image src={o.img} alt={o.alt} width={40} height={40} densities={[1, 2]} />
              <span>{o.name}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- 5. CTA 밴드 -->
  <section class="section cta">
    <div class="container">
      <div class="cta-band">
        <div class="cta-chars" aria-hidden="true">
          {
            greetChars.map((c) => (
              <Image
                src={c.states.happy}
                alt=""
                width={72}
                height={72}
                densities={[1, 2]}
              />
            ))
          }
        </div>
        <h2 class="cta-title">행동 전에 한 번 더 살펴보는 습관, 함께 시작해요</h2>
        <p class="cta-sub">
          글루밍즈 친구들과 함께, 오늘부터 내 혈당 흐름을 미리 그려봐요.<br />
          행동 전에 한 번 더 살펴보는 습관, 지금 같이 시작해요.
        </p>
        <Button href="/about#preregister" variant="primary" size="lg" class="cta-btn">
          사전예약 신청하기
        </Button>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── HERO ── */
  .hero {
    padding-top: clamp(64px, 9vw, 120px);
    padding-bottom: clamp(40px, 6vw, 72px);
  }
  .hero-inner {
    max-width: 820px;
  }
  .hero-title {
    font-size: clamp(34px, 5.8vw, 62px);
  }
  .hero-lead {
    margin-top: 24px;
    color: var(--text-2);
    font-size: clamp(16px, 2.1vw, 20px);
    line-height: 1.78;
    max-width: 680px;
  }
  /* 강조는 색이 아닌 굵기로만 (색 강조 금지) */
  .hero-lead strong,
  .section-sub strong,
  .sync-note strong,
  .cta-sub strong,
  .row-lead :global(strong) {
    color: inherit;
    font-weight: 700;
  }
  .hero-actions {
    margin-top: 36px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px;
  }

  /* ── DEEP-DIVE 행 ── 헤어라인으로 구분되는 비대칭 교차 배치 */
  .deepdives {
    padding-top: clamp(24px, 4vw, 48px);
  }
  .row {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(32px, 6vw, 88px);
    align-items: center;
    padding: clamp(48px, 7vw, 88px) 0;
    border-top: 1px solid var(--rule);
  }
  .row:first-child {
    border-top: 0;
    padding-top: clamp(24px, 4vw, 40px);
  }
  .row-reverse {
    grid-template-columns: 1.1fr 0.9fr;
  }
  .row-reverse .row-media {
    order: 2;
  }
  .row-media {
    display: flex;
    justify-content: center;
  }
  /* 앱 화면 목업(AppScreen)이 자리를 채운다 */
  .row-media > :global(.screen) {
    width: 100%;
    max-width: 440px;
  }
  .row-title {
    margin-top: 4px;
    font-size: clamp(26px, 3.6vw, 38px);
    letter-spacing: -0.04em;
  }
  .row-lead {
    margin-top: 18px;
    color: var(--text-2);
    font-size: clamp(15px, 1.9vw, 18px);
    line-height: 1.8;
    max-width: 560px;
  }
  .row-points {
    margin: 26px 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
  }
  .row-points li {
    position: relative;
    padding: 13px 0 13px 26px;
    color: var(--text);
    font-size: 15.5px;
    line-height: 1.6;
    border-top: 1px solid var(--rule);
  }
  .row-points li:last-child {
    border-bottom: 1px solid var(--rule);
  }
  .row-points li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 21px;
    width: 10px;
    height: 10px;
    border-radius: var(--r-pill);
    border: 1.5px solid var(--sage);
  }

  /* ── 건강 데이터 연동 ── */
  .sync {
    position: relative;
  }
  .sync .rule,
  .login .rule {
    border-color: var(--rule);
    margin: 0 0 clamp(56px, 8vw, 100px);
  }
  .sync-head {
    max-width: 680px;
  }
  .sync-chips {
    margin-top: clamp(32px, 5vw, 48px);
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }
  /* 광택 없는 납작한 헤어라인 칩 */
  .sync-chip {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 24px 16px 16px;
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: var(--r-md);
  }
  .sync-chip :global(img) {
    width: 48px;
    height: 48px;
    object-fit: contain;
    border-radius: var(--r-sm);
  }
  .sync-chip-text {
    display: flex;
    flex-direction: column;
    line-height: 1.35;
  }
  .sync-chip-text strong {
    font-size: 16px;
    font-weight: 700;
  }
  .sync-chip-text span {
    color: var(--text-3);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-family: var(--font-serif);
  }
  .sync-note {
    margin-top: 28px;
    max-width: 640px;
    color: var(--text-2);
    font-size: 15px;
    line-height: 1.78;
  }

  /* ── 간편 로그인 ── */
  .login-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }
  .login-text {
    max-width: 520px;
  }
  .login-icons {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .login-chip {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 10px 18px 10px 10px;
    background: transparent;
    border: 1px solid var(--rule);
    border-radius: var(--r-pill);
    font-weight: 600;
    font-size: 14.5px;
    color: var(--text);
  }
  .login-chip :global(img) {
    width: 26px;
    height: 26px;
    object-fit: contain;
    border-radius: var(--r-pill);
  }

  /* ── CTA 밴드 ── pine 다크 밴드, 납작하게 */
  .cta-band {
    background: var(--pine);
    color: var(--on-dark);
    border-radius: var(--r-2xl);
    padding: clamp(48px, 7vw, 88px) clamp(24px, 5vw, 64px);
    text-align: center;
  }
  .cta-chars {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-bottom: 24px;
  }
  .cta-chars :global(img) {
    width: clamp(52px, 9vw, 72px);
    height: auto;
  }
  .cta-title {
    font-size: clamp(24px, 4vw, 40px);
    max-width: 720px;
    margin-inline: auto;
    color: var(--on-dark);
  }
  .cta-sub {
    margin: 18px auto 32px;
    max-width: 520px;
    color: color-mix(in srgb, var(--on-dark) 78%, transparent);
    font-size: clamp(15px, 2vw, 18px);
    line-height: 1.7;
  }
  /* 다크 밴드 위 밝은 버튼 (pine 배경에 대비) */
  .cta-band :global(.cta-btn) {
    background: var(--on-dark);
    color: var(--pine);
  }
  .cta-band :global(.cta-btn:hover) {
    background: var(--primary-light);
    color: var(--pine);
  }

  /* ── 반응형 ──
     데스크톱(≥1024px): 위 규칙 그대로 — 넉넉한 좌우 교차 에디토리얼 행.
