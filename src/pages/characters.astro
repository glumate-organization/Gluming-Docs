---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import { Image } from 'astro:assets';
import {
  characters,
  ribuniCostumes,
  stateMeta,
  stateOrder,
} from '../lib/assets';

// 각 캐릭터별 따뜻한 성격 소개 (비의료 · 컨디션/무드 톤).
// set:html 로 렌더 — <strong>은 굵게 강조(색·이탤릭 X), <br />로 짧게 끊어 읽기 좋게.
const blurbs: Record<string, string> = {
  dodami:
    '도디는 하루의 작은 기록을 <strong>차곡차곡 모아두는 걸</strong> 제일 좋아해요.<br />' +
    '오늘 뭘 먹었는지, 얼마나 걸었는지 같이 들여다보고요.<br />' +
    '“오늘도 잘 챙겼어요” 하고 다정하게 토닥여 준답니다.<br />' +
    '<strong>든든한 맏이 같은 친구</strong>랄까요?',
  lumo:
    '루모는 하루의 흐름을 <strong>환하게 비춰 주는 친구</strong>예요.<br />' +
    '아침엔 가볍게 깨워 주고요.<br />' +
    '나른한 오후엔 “잠깐 스트레칭 어때요?” 하고 살며시 챙겨요.<br />' +
    '밝고 호기심 많아서, 루모랑 있으면 하루가 조금 더 산뜻해져요.',
  ppomi:
    '보미는 <strong>아주 작은 움직임에도 신나게 박수</strong>를 쳐 주는 응원 담당이에요.<br />' +
    '한 걸음, 두 걸음 늘어날 때마다 같이 폴짝폴짝 기뻐하고요.<br />' +
    '부담 없이 가볍게, 그래도 꾸준히 걷고 싶을 때 가장 든든해요.<br />' +
    '보미랑 같이 걸으면 왠지 한 걸음 더 걷고 싶어져요.',
  ribuni:
    '루코는 <strong>옷 갈아입는 재미에 진심</strong>인 멋쟁이 친구예요.<br />' +
    '그날 기분에 맞춰 코스튬을 골라 입고요.<br />' +
    '같이 꾸준히 지내다 보면 새 옷이 하나둘 늘어나요.<br />' +
    '모으는 재미가 쏠쏠해서, 매일이 조금 더 기대돼요.',
};
---

<Layout
  title="글루밍즈 — 글루밍의 컨디션 친구들"
  description="글루밍즈는 하루의 리듬을 함께 살피는 글루밍의 컨디션 친구들이에요. 도디·루모·보미·루코의 다양한 표정과 루코 코스튬 컬렉션을 만나보세요."
>
  <!-- ── HERO ─────────────────────────────────────────── -->
  <section class="hero section">
    <div class="container hero-inner">
      <div class="hero-copy">
        <span class="eyebrow">MEET THE GLUMINGS</span>
        <h1 class="section-title">하루의 리듬을 함께 살피는 네 친구</h1>
        <p class="section-sub">
          안녕하세요, 저희가 <strong>글루밍즈</strong>예요.<br />
          오늘의 기분과 컨디션을 살며시 비춰 주는 친구들이랍니다.<br />
          산뜻한 날엔 같이 신나고, 나른한 날엔 가만히 곁을 지켜요.<br />
          매일의 작은 습관, 저희랑 같이 챙겨보는 건 어떠세요?
        </p>
        <div class="hero-cta">
          <Button href="/about#preregister" variant="primary" size="lg"
            >글루밍즈와 함께 시작하기</Button
          >
        </div>
      </div>

      <ul class="hero-cluster" aria-label="글루밍즈 네 친구">
        {
          characters.map((c, i) => (
            <li class="hero-chip" style={`--accent:${c.accent}`}>
              <div class="hero-chip-art">
                <Image
                  src={c.states.optimal}
                  alt={`글루밍즈 ${c.name}`}
                  width={180}
                  height={180}
                  densities={[1, 2]}
                  loading={i === 0 ? 'eager' : 'lazy'}
                />
              </div>
              <span class="hero-chip-name">
                <span class="dot" aria-hidden="true" />
                {c.name}
              </span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ── 캐릭터별 섹션 ────────────────────────────────── -->
  {
    characters.map((c, i) => (
      <section
        class:list={['char-section', { alt: i % 2 === 1 }]}
        style={`--accent:${c.accent}`}
        aria-labelledby={`char-${c.key}`}
      >
        <div class="container char-grid">
          <div class="char-art">
            <Image
              src={c.states.happy}
              alt={`글루밍즈 ${c.name}의 모습`}
              width={360}
              height={360}
              densities={[1, 2]}
              loading="lazy"
            />
          </div>

          <div class="char-info">
            <div class="char-index">
              <span class="char-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="char-dot" aria-hidden="true" />
              <span class="char-eyebrow">GLUMINGS</span>
            </div>
            <h2 id={`char-${c.key}`}>{c.name}</h2>
            <span class="char-underline" aria-hidden="true" />
            <p class="char-tagline">{c.tagline}</p>
            <p class="char-blurb" set:html={blurbs[c.key]} />

            <div class="faces">
              <h3 class="faces-title">표정 모아보기</h3>
              <ul class="faces-row">
                {stateOrder.map((s) => (
                  <li class="face">
                    <div class="face-art">
                      <Image
                        src={c.states[s]}
                        alt={`${c.name}의 ${stateMeta[s].label} 표정`}
                        width={120}
                        height={120}
                        densities={[1, 2]}
                        loading="lazy"
                      />
                    </div>
                    <span
                      class="face-badge"
                      style={`background:${stateMeta[s].bg};color:${stateMeta[s].fg}`}
                    >
                      {stateMeta[s].label}
                    </span>
                  </li>
                ))}
              </ul>
              <p class="faces-note">
                오늘의 기분과 컨디션에 따라 표정이 <strong>살며시 바뀌어요.</strong>
              </p>
            </div>
          </div>
        </div>
      </section>
    ))
  }

  <!-- ── 루코 코스튬 컬렉션 ─────────────────────────── -->
  <section class="costumes section" style="--accent: var(--berry)">
    <div class="container">
      <hr class="rule costumes-rule" />
      <div class="costumes-head">
        <span class="eyebrow">RIBUNI'S WARDROBE</span>
        <h2 class="section-title">
          루코는 옷을 갈아입으며 모으는 재미가 있어요
        </h2>
        <p class="section-sub">
          글루밍즈와 꾸준히 지내다 보면 루코의 옷장이 <strong>점점 풍성해져요.</strong><br />
          그날의 기분에 맞춰 골라 입는 코스튬, 하나씩 같이 모아볼까요?
        </p>
      </div>

      <ul class="costume-grid">
        {
          ribuniCostumes.map(({ label, img }) => (
            <li class="costume-card card">
              <div class="costume-art">
                <Image
                  src={img}
                  alt={`루코 ${label} 코스튬`}
                  width={160}
                  height={160}
                  densities={[1, 2]}
                  loading="lazy"
                />
              </div>
              <span class="costume-label">
                <span class="dot" aria-hidden="true" />
                {label}
              </span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ── CTA ──────────────────────────────────────────── -->
  <section class="cta-band section">
    <div class="container cta-inner">
      <hr class="rule cta-rule" />
      <span class="eyebrow">START TOGETHER</span>
      <h2 class="cta-title">글루밍즈와 함께 시작해 볼까요?</h2>
      <p class="cta-sub">
        네 친구가 매일의 리듬을 <strong>곁에서 함께 살펴 줄게요.</strong><br />
        지금 사전예약하고 가장 먼저 만나보세요.
      </p>
      <Button href="/about#preregister" variant="primary" size="lg"
        >글루밍즈와 함께 시작하기</Button
      >
    </div>
  </section>
</Layout>

<style>
  /* ── HERO ───────────────────────────────────────── */
  .hero {
    padding-top: clamp(48px, 7vw, 96px);
    padding-bottom: clamp(48px, 7vw, 88px);
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(28px, 5vw, 72px);
    align-items: center;
  }
  .hero-cta {
    margin-top: 30px;
  }

  .hero-cluster {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(16px, 3vw, 28px);
  }
  .hero-chip {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    padding: clamp(14px, 2vw, 22px) 8px;
  }
  .hero-chip-art {
    width: 100%;
    aspect-ratio: 1 / 1;
    display: grid;
    place-items: center;
    padding: 10%;
  }
  .hero-chip-art :global(img) {
    width: 100%;
    height: auto;
    object-fit: contain;
    transition: transform 0.22s ease;
  }
  .hero-chip:hover .hero-chip-art :global(img) {
    transform: translateY(-4px);
  }
  .hero-chip-name {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 15px;
    letter-spacing: -0.01em;
  }
  .hero-chip-name .dot {
    width: 7px;
    height: 7px;
    border-radius: var(--r-pill);
    background: var(--accent);
  }

  /* ── 캐릭터 섹션 ─────────────────────────────────── */
  .char-section {
    padding: clamp(56px, 8vw, 104px) 0;
    border-top: 1px solid var(--rule);
    background: var(--bg);
  }
  .char-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(32px, 6vw, 80px);
    align-items: center;
  }
  .char-section.alt .char-art {
    order: 2;
  }

  .char-art {
    border: 1px solid var(--rule);
    border-radius: var(--r-lg);
    background: var(--surface);
    display: grid;
    place-items: center;
    padding: clamp(32px, 5vw, 64px);
    aspect-ratio: 1 / 1;
  }
  .char-art :global(img) {
    width: 78%;
    height: auto;
    object-fit: contain;
  }

  .char-index {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
  }
  .char-num {
    font-family: var(--font-serif);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--text-3);
  }
  .char-dot {
    width: 7px;
    height: 7px;
    border-radius: var(--r-pill);
    background: var(--accent);
  }
  .char-eyebrow {
    font-family: var(--font-serif);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--sage-dark);
  }
  .char-info h2 {
    font-size: clamp(28px, 4vw, 44px);
    letter-spacing: -0.04em;
  }
  .char-underline {
    display: block;
    width: 40px;
    height: 2px;
    margin-top: 16px;
    background: var(--accent);
  }
  .char-tagline {
    margin-top: 16px;
    font-size: clamp(16px, 2vw, 19px);
    font-weight: 600;
    color: var(--text);
  }
  .char-blurb {
    margin-top: 14px;
    color: var(--text-2);
    font-size: 16px;
    line-height: 1.85;
    max-width: 560px;
  }

  /* 표정 모아보기 */
  .faces {
    margin-top: 36px;
    padding-top: 28px;
    border-top: 1px solid var(--rule);
  }
  .faces-title {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--text-2);
  }
  .faces-row {
    list-style: none;
    margin: 18px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 12px;
  }
  .face {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  .face-art {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: var(--r-md);
    background: var(--surface);
    border: 1px solid var(--rule);
    display: grid;
    place-items: center;
    padding: 10px;
  }
  .face-art :global(img) {
    width: 84%;
    height: auto;
    object-fit: contain;
  }
  .face-badge {
    font-size: 11px;
    font-weight: 700;
    padding: 3px 9px;
    border-radius: var(--r-pill);
    white-space: nowrap;
    letter-spacing: -0.01em;
  }
  .faces-note {
    margin-top: 18px;
    font-size: 13.5px;
    color: var(--text-3);
  }

  /* ── 코스튬 컬렉션 ───────────────────────────────── */
  .costumes {
    padding-top: 0;
  }
  .costumes-rule {
    margin: 0 0 clamp(48px, 8vw, 96px);
  }
  .costumes-head {
    max-width: var(--measure);
  }
  .costume-grid {
    list-style: none;
    margin: clamp(36px, 5vw, 56px) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 16px;
  }
  .costume-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    padding: 20px 14px;
    transition: transform 0.18s ease;
  }
  .costume-card:hover {
    transform: translateY(-3px);
  }
  .costume-art {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: var(--r-md);
    background: var(--warm);
    display: grid;
    place-items: center;
    padding: 14px;
  }
  .costume-art :global(img) {
    width: 80%;
    height: auto;
    object-fit: contain;
  }
  .costume-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: 14.5px;
  }
  .costume-label .dot {
    width: 6px;
    height: 6px;
    border-radius: var(--r-pill);
    background: var(--accent);
  }

  /* ── CTA ─────────────────────────────────────────── */
  .cta-band {
    text-align: center;
  }
  .cta-rule {
    margin: 0 auto clamp(40px, 6vw, 72px);
    max-width: var(--measure);
  }
  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .cta-title {
    font-size: clamp(28px, 4vw, 46px);
    letter-spacing: -0.04em;
  }
  .cta-sub {
    margin: 18px auto 30px;
    color: var(--text-2);
    font-size: clamp(16px, 2vw, 18px);
    line-height: 1.75;
    max-width: 520px;
  }

  /* ── 반응형 ──────────────────────────────────────── */

  /* 데스크톱 (≥1024px): 넉넉한 여백 · 에디토리얼 프레이밍 유지 */
  @media (min-width: 1024px) {
    .hero-inner {
      gap: clamp(56px, 6vw, 80px);
    }
    .char-grid {
      gap: clamp(56px, 6vw, 88px);
    }
    .char-blurb {
      font-size: 16.5px;
    }
  }

  /* 태블릿 (≤900px): 2단 → 1단 세로 스택 (이미지 먼저, 텍스트 다음) */
  @media (max-width: 900px) {
    .hero-inner,
    .char-grid {
      grid-template-columns: 1fr;
    }
    .char-section.alt .char-art {
      order: 0;
    }
    .char-art {
      max-width: 380px;
      margin-inline: auto;
    }
    .faces-row {
      grid-template-columns: repeat(3, 1fr);
    }
    .costume-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* 모바일 (≤640px): 진짜 모바일 레이아웃 — 타이트한 여백·큰 터치타깃·작은 타이포 */
  @media (max-width: 640px) {
    .hero {
      padding-top: clamp(32px, 9vw, 56px);
      padding-bottom: clamp(32px, 9vw, 48px);
    }
    .hero-inner {
      gap: 26px;
      text-align: center;
    }
    .hero-copy .section-sub {
      margin-inline: auto;
    }
    .hero-cta {
      display: flex;
      justify-content: center;
      margin-top: 24px;
    }

    /* 4친구 히어로 — 편안한 모바일 2열 카드 그리드 */
    .hero-cluster {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
      max-width: 420px;
      margin-inline: auto;
    }
    .hero-chip {
      gap: 10px;
      padding: 16px 8px;
      background: var(--surface);
      border: 1px solid var(--rule);
      border-radius: var(--r-lg);
    }
    .hero-chip-art {
      padding: 14%;
    }

    /* 캐릭터 섹션 — 세로 스택 · 여백 축소 · 이미지 축소 */
    .char-section {
      padding: 44px 0;
    }
    .char-grid {
      gap: 22px;
    }
    .char-art {
      max-width: 260px;
      padding: 26px;
    }
    .char-index {
      margin-bottom: 14px;
    }
    .char-info h2 {
      font-size: 26px;
    }
    .char-tagline {
      margin-top: 14px;
      font-size: 16px;
    }
    .char-blurb {
      margin-top: 12px;
      font-size: 15px;
      line-height: 1.8;
    }

    /* 표정 모아보기 — 가로 스와이프 스트립 (스냅 · 큰 터치타깃 · 화면 끝까지 블리드) */
    .faces {
      margin-top: 28px;
      padding-top: 22px;
    }
    .faces-row {
      display: flex;
      grid-template-columns: none;
      gap: 12px;
      margin: 16px -24px 0;
      padding: 2px 24px;
      overflow-x: auto;
      scroll-snap-type: x proximity;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .faces-row::-webkit-scrollbar {
      display: none;
    }
    .face {
      flex: 0 0 90px;
      gap: 8px;
      scroll-snap-align: start;
    }
    .face-badge {
      font-size: 11.5px;
      padding: 4px 10px;
    }

    /* 코스튬 — 2열 · 넓은 터치 영역 */
    .costume-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
    .costume-card {
      padding: 18px 12px;
    }

    .cta-title {
      font-size: 26px;
    }
    .cta-sub {
      margin-top: 16px;
    }
  }
</style>
